{
  "appId": "net.micapeak.SawmillCalculatorPro",
  "appName": "Sawmill Calculator Pro",
  "webDir": "dist",
  "plugins": {
    "StatusBar": {
      "overlaysWebView": false,
      "backgroundColor": "#ffffff",
      "style": "DARK"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "androidScaleType": "CENTER_CROP"
    }
  },
  "ios": {
    "contentInset": "always"
  },
  "android": {
    "allowMixedContent": false
  },
  "experimental": {
    "ios": {
      "spm": {
        "swiftToolsVersion": "6.1",
        "packageTraits": {
          "@capacitor-firebase/analytics": ["AnalyticsWithoutAdIdSupport"]
        }
      }
    }
  }
}
